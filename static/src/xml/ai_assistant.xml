<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- ============================================================ -->
    <!-- Assistant — AI chat panel                                    -->
    <!-- ============================================================ -->
    <t t-name="setdb_ui.Assistant">
        <div class="setdb-ai-panel">
            <!-- Header -->
            <div class="setdb-ai-header">
                <i class="fa fa-robot text-primary"/>
                <span>AI Assistant</span>
                <div class="ms-auto d-flex gap-1">
                    <button class="btn btn-sm btn-outline-secondary" t-on-click="newSession"
                            title="New conversation">
                        <i class="fa fa-plus"/>
                    </button>
                </div>
            </div>

            <!-- Messages area -->
            <div class="setdb-ai-messages" t-ref="messages">
                <!-- Welcome screen when no messages -->
                <t t-if="!hasMessages">
                    <div class="text-center p-3">
                        <i class="fa fa-comments fa-3x text-muted mb-3 d-block"/>
                        <p class="text-muted mb-2">Ask me anything about your SetDB data.</p>
                        <p class="text-muted small mb-3">
                            I can help write SetQL queries, explain hierarchies,
                            and suggest optimizations.
                        </p>
                        <div class="d-flex flex-column gap-2">
                            <t t-foreach="quickPrompts" t-as="prompt" t-key="prompt_index">
                                <button class="btn btn-sm btn-outline-primary text-start"
                                        t-on-click="() => this.askQuickPrompt(prompt)">
                                    <i class="fa fa-lightbulb-o me-1"/>
                                    <t t-esc="prompt"/>
                                </button>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- Message list -->
                <t t-foreach="state.messages" t-as="msg" t-key="msg_index">
                    <div t-att-class="'setdb-ai-message ' + msg.role">
                        <t t-out="formatContent(msg.content)"/>

                        <!-- Suggestions for assistant messages -->
                        <t t-if="msg.role === 'assistant' and msg.suggestions.length > 0">
                            <t t-foreach="msg.suggestions" t-as="sug" t-key="sug_index">
                                <SetDBSuggestion
                                    query="sug.query or ''"
                                    action_json="sug.action_json or ''"
                                    onApply.bind="onApplySuggestion"/>
                            </t>
                        </t>
                    </div>
                </t>

                <!-- Typing indicator -->
                <div t-if="state.is_typing" class="setdb-ai-typing">
                    <span/><span/><span/>
                </div>
            </div>

            <!-- Input area -->
            <div class="setdb-ai-input">
                <textarea
                    placeholder="Ask about SetDB..."
                    t-att-value="state.input_text"
                    t-on-input="onInputChange"
                    t-on-keydown="onInputKeydown"
                    t-att-disabled="state.is_typing"
                    rows="1"/>
                <button class="btn btn-primary btn-sm align-self-end"
                        t-att-disabled="!state.input_text.trim() or state.is_typing"
                        t-on-click="sendMessage">
                    <i class="fa fa-paper-plane"/>
                </button>
            </div>
        </div>
    </t>

    <!-- ============================================================ -->
    <!-- Suggestion — Suggested query/action widget                   -->
    <!-- ============================================================ -->
    <t t-name="setdb_ui.Suggestion">
        <div class="setdb-ai-suggestion">
            <t t-if="hasQuery">
                <div class="mb-1 small text-muted">
                    <i class="fa fa-code me-1"/>Suggested Query:
                </div>
                <pre class="mb-1 p-2 bg-white rounded border" style="font-size: 0.85em; white-space: pre-wrap;"><code t-esc="displayQuery"/></pre>
            </t>
            <t t-if="hasAction">
                <div class="mb-1 small text-muted">
                    <i class="fa fa-bolt me-1"/>
                    <t t-esc="actionLabel"/>
                </div>
            </t>
            <div class="d-flex gap-2">
                <button class="apply-btn" t-on-click="onApplyClick">
                    <i class="fa fa-play me-1"/>Apply to Query Studio
                </button>
                <button t-if="hasQuery"
                        class="apply-btn" style="background: #78909c;"
                        t-on-click="onCopyClick">
                    <i class="fa fa-copy me-1"/>Copy
                </button>
            </div>
        </div>
    </t>

</templates>
