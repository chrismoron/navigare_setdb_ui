<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                       LIST VIEW                              -->
    <!-- ============================================================ -->
    <record id="view_setdb_mail_query_list" model="ir.ui.view">
        <field name="name">setdb.mail.query.list</field>
        <field name="model">setdb.mail.query</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="response_format"/>
                <field name="max_results"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                       FORM VIEW                              -->
    <!-- ============================================================ -->
    <record id="view_setdb_mail_query_form" model="ir.ui.view">
        <field name="name">setdb.mail.query.form</field>
        <field name="model">setdb.mail.query</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="alias_id"/>
                            <field name="allowed_user_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="response_format"/>
                            <field name="max_results"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                      KANBAN VIEW                             -->
    <!-- ============================================================ -->
    <record id="view_setdb_mail_query_kanban" model="ir.ui.view">
        <field name="name">setdb.mail.query.kanban</field>
        <field name="model">setdb.mail.query</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="card">
                        <field name="name" class="fw-bold fs-5"/>
                        <div class="mt-2">
                            <field name="response_format" widget="badge"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                       ACTION                                 -->
    <!-- ============================================================ -->
    <record id="action_setdb_mail_queries" model="ir.actions.act_window">
        <field name="name">Mail Queries</field>
        <field name="res_model">setdb.mail.query</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Set up mail-based query access
            </p>
        </field>
    </record>

</odoo>
