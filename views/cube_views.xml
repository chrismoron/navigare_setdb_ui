<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                       LIST VIEW                              -->
    <!-- ============================================================ -->
    <record id="view_setdb_cube_list" model="ir.ui.view">
        <field name="name">setdb.cube.list</field>
        <field name="model">setdb.cube</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="row_hierarchy_id"/>
                <field name="column_hierarchy_id"/>
                <field name="measure_ids" widget="many2many_tags"/>
                <field name="author_id"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                       FORM VIEW                              -->
    <!-- ============================================================ -->
    <record id="view_setdb_cube_form" model="ir.ui.view">
        <field name="name">setdb.cube.form</field>
        <field name="model">setdb.cube</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="compute_grid" type="object"
                            string="Open in Cube Explorer"
                            class="oe_highlight" icon="fa-th"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="row_hierarchy_id"/>
                            <field name="column_hierarchy_id"/>
                            <field name="filter_hierarchy_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="show_row_totals"/>
                            <field name="show_col_totals"/>
                            <field name="show_grand_total"/>
                            <field name="auto_materialize"/>
                            <field name="default_row_depth"/>
                            <field name="default_col_depth"/>
                            <field name="author_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Measures">
                            <div class="mb-2">
                                <button name="action_open_measure_wizard" type="object"
                                        string="Add Measure" class="btn-secondary btn-sm"
                                        icon="fa-plus"/>
                            </div>
                            <field name="measure_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="metadata_key"/>
                                    <field name="aggregation"/>
                                    <field name="format_string"/>
                                    <field name="sequence"/>
                                </list>
                            </field>
                        </page>
                        <page string="Formulas">
                            <div class="mb-2">
                                <button name="action_open_formula_wizard" type="object"
                                        string="Add Formula" class="btn-secondary btn-sm"
                                        icon="fa-plus"/>
                            </div>
                            <field name="formula_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="formula_text"/>
                                    <field name="axis"/>
                                    <field name="sequence"/>
                                    <field name="style"/>
                                    <field name="is_percentage"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                      KANBAN VIEW                             -->
    <!-- ============================================================ -->
    <record id="view_setdb_cube_kanban" model="ir.ui.view">
        <field name="name">setdb.cube.kanban</field>
        <field name="model">setdb.cube</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="card">
                        <field name="name" class="fw-bold fs-5"/>
                        <div class="mt-1">
                            <span class="text-muted">Rows:</span>
                            <field name="row_hierarchy_id"/>
                        </div>
                        <div>
                            <span class="text-muted">Cols:</span>
                            <field name="column_hierarchy_id"/>
                        </div>
                        <div class="mt-2">
                            <field name="measure_ids" widget="many2many_tags"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                       ACTION                                 -->
    <!-- ============================================================ -->
    <record id="action_setdb_cubes" model="ir.actions.act_window">
        <field name="name">Cube Definitions</field>
        <field name="res_model">setdb.cube</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define your first OLAP cube
            </p>
        </field>
    </record>

</odoo>
