<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--         INHERIT res.config.settings FORM - SetDB UI          -->
    <!-- ============================================================ -->
    <record id="view_setdb_ui_config_settings" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.setdb_ui</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="SetDB UI" string="SetDB UI" name="setdb_ui" groups="base.group_system">
                    <block title="AI Assistant"
                           help="Configure the AI assistant for natural-language queries and suggestions.">
                        <setting string="API Key"
                                 help="API key for the external AI model provider.">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="setdb_ai_api_key" password="True"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="AI Model"
                                 help="Model identifier (e.g. claude-sonnet-4-20250514).">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="setdb_ai_model"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Max Tokens"
                                 help="Maximum number of tokens per AI response.">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="setdb_ai_max_tokens"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Auto-Materialize"
                                 help="Automatically materialize views suggested by the AI.">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="setdb_ai_auto_materialize"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                       ACTION                                 -->
    <!-- ============================================================ -->
    <record id="action_setdb_ui_config" model="ir.actions.act_window">
        <field name="name">SetDB UI Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'module': 'setdb_ui'}</field>
    </record>

</odoo>
