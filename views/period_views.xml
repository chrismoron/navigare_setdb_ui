<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                       LIST VIEW                              -->
    <!-- ============================================================ -->
    <record id="view_setdb_period_config_list" model="ir.ui.view">
        <field name="name">setdb.period.config.list</field>
        <field name="model">setdb.period.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="fiscal_year_start_month"/>
                <field name="year_start"/>
                <field name="year_end"/>
                <field name="hierarchy_id"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                       FORM VIEW                              -->
    <!-- ============================================================ -->
    <record id="view_setdb_period_config_form" model="ir.ui.view">
        <field name="name">setdb.period.config.form</field>
        <field name="model">setdb.period.config</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_period_wizard" type="object"
                            string="Period Generation Wizard" icon="fa-magic"/>
                    <button name="action_generate" type="object"
                            string="Generate Periods"
                            class="oe_highlight" icon="fa-calendar"
                            confirm="This will generate all period elements. Continue?"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="fiscal_year_start_month"/>
                            <field name="year_start"/>
                            <field name="year_end"/>
                        </group>
                        <group>
                            <field name="generate_days"/>
                            <field name="generate_weeks"/>
                            <field name="generate_months"/>
                            <field name="generate_quarters"/>
                            <field name="hierarchy_id" readonly="1"/>
                            <field name="sigma_algebra_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                      KANBAN VIEW                             -->
    <!-- ============================================================ -->
    <record id="view_setdb_period_config_kanban" model="ir.ui.view">
        <field name="name">setdb.period.config.kanban</field>
        <field name="model">setdb.period.config</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="card">
                        <field name="name" class="fw-bold fs-5"/>
                        <div class="mt-1">
                            <span class="text-muted">Years:</span>
                            <field name="year_start"/> - <field name="year_end"/>
                        </div>
                        <div class="mt-1">
                            <span class="text-muted">Hierarchy:</span>
                            <field name="hierarchy_id"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                       ACTION                                 -->
    <!-- ============================================================ -->
    <record id="action_setdb_period_configs" model="ir.actions.act_window">
        <field name="name">Period Configurations</field>
        <field name="res_model">setdb.period.config</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure your first period hierarchy
            </p>
        </field>
    </record>

</odoo>
