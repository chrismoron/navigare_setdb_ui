<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                 UI PROFILE - LIST VIEW                       -->
    <!-- ============================================================ -->
    <record id="view_setdb_ui_profile_list" model="ir.ui.view">
        <field name="name">setdb.ui.profile.list</field>
        <field name="model">setdb.ui.profile</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="user_id"/>
                <field name="is_default"/>
                <field name="is_shared"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                 UI PROFILE - FORM VIEW                       -->
    <!-- ============================================================ -->
    <record id="view_setdb_ui_profile_form" model="ir.ui.view">
        <field name="name">setdb.ui.profile.form</field>
        <field name="model">setdb.ui.profile</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="user_id"/>
                            <field name="is_default"/>
                            <field name="is_shared"/>
                        </group>
                        <group>
                            <field name="default_cube_id"/>
                            <field name="default_query_id"/>
                        </group>
                    </group>
                    <separator string="Dashboard Layout"/>
                    <field name="dashboard_layout_json" widget="ace" options="{'mode': 'json'}"/>
                    <separator string="Keyboard Shortcuts"/>
                    <field name="keyboard_shortcuts_json" widget="ace" options="{'mode': 'json'}"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                 UI TEMPLATE - LIST VIEW                      -->
    <!-- ============================================================ -->
    <record id="view_setdb_ui_template_list" model="ir.ui.view">
        <field name="name">setdb.ui.template.list</field>
        <field name="model">setdb.ui.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="template_type"/>
                <field name="description"/>
                <field name="tags"/>
                <field name="is_system" widget="boolean"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                 UI TEMPLATE - FORM VIEW                      -->
    <!-- ============================================================ -->
    <record id="view_setdb_ui_template_form" model="ir.ui.view">
        <field name="name">setdb.ui.template.form</field>
        <field name="model">setdb.ui.template</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_apply" type="object"
                            string="Apply Template"
                            class="oe_highlight" icon="fa-check"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="template_type"/>
                            <field name="tags"/>
                        </group>
                        <group>
                            <field name="description"/>
                            <field name="is_system"/>
                        </group>
                    </group>
                    <separator string="Configuration"/>
                    <field name="config_json" widget="ace" options="{'mode': 'json'}"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                       ACTIONS                                -->
    <!-- ============================================================ -->
    <record id="action_setdb_ui_profiles" model="ir.actions.act_window">
        <field name="name">Profiles</field>
        <field name="res_model">setdb.ui.profile</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first UI profile
            </p>
        </field>
    </record>

    <record id="action_setdb_ui_templates" model="ir.actions.act_window">
        <field name="name">Templates</field>
        <field name="res_model">setdb.ui.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first UI template
            </p>
        </field>
    </record>

</odoo>
